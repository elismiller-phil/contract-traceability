
@prefix : <http://example.org/contract-lifecycle#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ContractLifecycleOntology rdf:type owl:Ontology ;
    rdfs:label "Defense Contract Lifecycle Ontology v2" .

#################################################################
# Core Classes
#################################################################

:Contract rdf:type owl:Class .
:ContractModification rdf:type owl:Class .
:Organization rdf:type owl:Class .
:ContractorOrganization rdf:type owl:Class ;
    rdfs:subClassOf :Organization .

:GovernmentOrganization rdf:type owl:Class ;
    rdfs:subClassOf :Organization .

:Person rdf:type owl:Class .
:Role rdf:type owl:Class .
:LegalContractorRole rdf:type owl:Class ;
    rdfs:subClassOf :Role .

:ContractingOfficerRepresentativeRole rdf:type owl:Class ;
    rdfs:subClassOf :Role .

:TemporalInterval rdf:type owl:Class .
:RoleAssignment rdf:type owl:Class .
:ContractEvent rdf:type owl:Class .
:InstitutionalAct rdf:type owl:Class .
:ModificationIssuanceEvent rdf:type owl:Class ;
    rdfs:subClassOf :InstitutionalAct .

:InformationArtifact rdf:type owl:Class .
:ModificationDocument rdf:type owl:Class ;
    rdfs:subClassOf :InformationArtifact .

:ContractStateTransition rdf:type owl:Class .

#################################################################
# Properties
#################################################################

:hasContractNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain :Contract ;
    rdfs:range xsd:string .

:hasStartDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

:hasEndDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

:hasIssueDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

:hasLegalContractor rdf:type owl:ObjectProperty ;
    rdfs:domain :Contract ;
    rdfs:range :ContractorOrganization .

:hasCOR rdf:type owl:ObjectProperty ;
    rdfs:domain :Contract ;
    rdfs:range :Person .

:hasModification rdf:type owl:ObjectProperty ;
    rdfs:domain :Contract ;
    rdfs:range :ContractModification .

:replacesLegalContractor rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractModification ;
    rdfs:range :ContractorOrganization .

:substitutesLegalContractor rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractModification ;
    rdfs:range :ContractorOrganization .

:replacesCOR rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractModification ;
    rdfs:range :Person .

:substitutesCOR rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractModification ;
    rdfs:range :Person .

:assignedRole rdf:type owl:ObjectProperty ;
    rdfs:domain :RoleAssignment ;
    rdfs:range :Role .

:assignedTo rdf:type owl:ObjectProperty ;
    rdfs:domain :RoleAssignment ;
    rdfs:range owl:Thing .

:validDuring rdf:type owl:ObjectProperty ;
    rdfs:domain :RoleAssignment ;
    rdfs:range :TemporalInterval .

:appliesToContract rdf:type owl:ObjectProperty ;
    rdfs:domain :RoleAssignment ;
    rdfs:range :Contract .

:documents rdf:type owl:ObjectProperty ;
    rdfs:domain :ModificationDocument ;
    rdfs:range :InstitutionalAct .

:producesStateTransition rdf:type owl:ObjectProperty ;
    rdfs:domain :InstitutionalAct ;
    rdfs:range :ContractStateTransition .

:changesContractState rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractStateTransition ;
    rdfs:range :Contract .

:resultsInContractorSubstitution rdf:type owl:ObjectProperty ;
    rdfs:domain :ContractStateTransition ;
    rdfs:range :ContractorOrganization .

#################################################################
# Core Individuals
#################################################################

:Contract_W912DY_23_C_0047 rdf:type :Contract ;
