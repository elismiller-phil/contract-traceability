:BeaconDefenseIndustries rdf:type :ContractorOrganization ;
    rdfs:label "Beacon Defense Industries" .

:JamesLiu rdf:type :Person ;
    rdfs:label "Capt. James Liu" .

:SarahChen rdf:type :Person ;
    rdfs:label "Maj. Sarah Chen" .

:TalismanLegalContractorRoleInstance rdf:type :LegalContractorRole .
:BeaconLegalContractorRoleInstance rdf:type :LegalContractorRole .

:InitialCORRoleInstance rdf:type :ContractingOfficerRepresentativeRole .
:ReplacementCORRoleInstance rdf:type :ContractingOfficerRepresentativeRole .

#################################################################
# Temporal Intervals
#################################################################

:Interval_TalismanContractorPeriod rdf:type :TemporalInterval ;
    :hasStartDate "2023-03-01"^^xsd:date ;
    :hasEndDate "2024-10-01"^^xsd:date .

:Interval_BeaconContractorPeriod rdf:type :TemporalInterval ;
    :hasStartDate "2024-10-01"^^xsd:date ;
    :hasEndDate "2026-05-01"^^xsd:date .

